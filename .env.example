# Copy to .env and fill in your values

# LLM Provider: "claude" (default) or "deepseek"
LLM_PROVIDER=claude

# Anthropic (used when LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-xxxx
# LLM_MODEL=claude-haiku-4-5-20251001

# DeepSeek (used when LLM_PROVIDER=deepseek)
# DEEPSEEK_API_KEY=sk-xxxx
# LLM_MODEL=deepseek-chat

# URL used by the browser to call the API
# For local Docker: keep the default (localhost:8000 is exposed on the host)
# For production: change to your domain, e.g. https://api.example.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
